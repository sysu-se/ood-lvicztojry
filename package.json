{
	"name": "sudoku",
	"version": "1.0.0",
	"scripts": {
		"prebuild": "rimraf dist && mkdir dist",
		"build:css": "npx tailwindcss -i ./src/styles/global.css -o ./dist/bundle.css --minify",
		"build:js": "rollup -c --environment NODE_ENV:production",
		"build": "npm run build:css && npm run build:js",
		"postbuild": "node scripts/postbuild.js",
		"predev": "rimraf dist",
		"dev": "npm run build:css && rollup -c -w",
		"start": "sirv dist",
		"test": "vitest run",
		"test:contract": "vitest run tests/hw1/01-contract.test.js",
		"test:sudoku": "vitest run tests/hw1/02-sudoku-basic.test.js",
		"test:clone": "vitest run tests/hw1/03-clone.test.js",
		"test:game": "vitest run tests/hw1/04-game-undo-redo.test.js",
		"test:serialization": "vitest run tests/hw1/05-serialization.test.js"
	},
	"devDependencies": {
		"@rollup/plugin-alias": "^3.1.9",
		"@rollup/plugin-commonjs": "^20.0.0",
		"@rollup/plugin-node-resolve": "^13.0.0",
		"autoprefixer": "^10.4.0",
		"inline-critical": "^6.0.1",
		"postcss": "^8.3.11",
		"postcss-clean": "^1.2.2",
		"postcss-import": "^13.0.0",
		"postcss-load-config": "^3.1.4",
		"reaver": "^2.0.0",
		"rimraf": "^3.0.2",
		"rollup": "^2.79.1",
		"rollup-plugin-copy": "^3.4.0",
		"rollup-plugin-css-only": "^3.1.0",
		"rollup-plugin-livereload": "^2.0.5",
		"rollup-plugin-svelte": "^7.1.6",
		"rollup-plugin-terser": "^7.0.2",
		"svelte": "^3.52.0",
		"svelte-preprocess": "^5.1.4",
		"vitest": "^0.23.4"
	},
	"dependencies": {
		"@mattflow/sudoku-solver": "^2.2.0",
		"fake-sudoku-puzzle-generator": "^1.2.1",
		"sirv-cli": "^2.0.2",
		"tailwindcss": "^3.3.3"
	}
}
